# Secrets / env
.env
.env.*
!.env.example
*.key
*.pem
secrets.*

# Office source binaries (PDF export is the canonical tracked artifact)
*.xlsx
*.docx
*.pptx

# Python / Node build + env
__pycache__/
*.py[cod]
.venv/
node_modules/
dist/
build/

# OS
.DS_Store
Thumbs.db

# Reference books / third-party PDFs: contents untracked by default (copyright +
# bloat), but keep the folder's purpose documented. The two study-session PDFs are
# explicitly whitelisted below (private repo).
books/*
!books/README.md
!books/agentic-coding-claude-code.pdf
!books/agentic-coding-claude-code-imgs.pdf
!books/agentic-design-patterns.pdf

# Cloned third-party reference repos (book companion code): NEVER tracked.
# Cloned locally for study only; their own upstream licenses govern that code.
reference/
